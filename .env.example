# --------------------------------------------------------------------
# PMS - Enterprise Project Management System Environment Setup Example
# --------------------------------------------------------------------

# Application configuration settings
PROJECT_NAME="Project Management System API"
API_V1_STR="/api/v1"

# Database Connection (PostgreSQL)
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgrespassword
POSTGRES_DB=pms_db
POSTGRES_PORT=5432

# Redis Cache Configurations
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Security & JWT Configuration
# Run 'openssl rand -hex 32' to generate a secure secret key.
SECRET_KEY=PROD_REPLACE_ME_SECRET_KEY_JWT_987654321
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Throttling limit (Requests per IP per minute)
RATE_LIMIT_PER_MINUTE=60

# Initial Admin Seeding Configuration
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=Admin@1234!
